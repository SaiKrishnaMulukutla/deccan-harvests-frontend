# New file: `components/CounterUp.tsx`

```tsx
'use client';

import { useEffect, useRef } from 'react';
import {
  motion,
  useInView,
  useMotionValue,
  useTransform,
  animate,
} from 'framer-motion';

interface CounterUpProps {
  to: number;
  suffix?: string;
  duration?: number;
}

export function CounterUp({ to, suffix = '+', duration = 2.2 }: CounterUpProps) {
  const ref = useRef<HTMLSpanElement>(null);
  const inView = useInView(ref, { once: true, margin: '0px 0px -15% 0px' });
  const mv = useMotionValue(0);
  const rounded = useTransform(mv, (v) => `${Math.round(v).toLocaleString()}${suffix}`);

  useEffect(() => {
    if (!inView) return;
    const controls = animate(mv, to, {
      duration,
      ease: [0.16, 1, 0.3, 1], // matches the rest of the site's "premium" easing
    });
    // hard fallback if Lenis/observer drift causes the value to stall
    const fail = setTimeout(() => mv.set(to), duration * 1000 + 500);
    return () => {
      controls.stop();
      clearTimeout(fail);
    };
  }, [inView, to, duration, mv]);

  return <motion.span ref={ref}>{rounded}</motion.span>;
}
```

Usage:

```tsx
<CounterUp to={42} suffix="+" />          {/* Countries */}
<CounterUp to={3500} suffix="+" />        {/* Tons */}
<CounterUp to={180} suffix="+" />         {/* Partners */}
<CounterUp to={15} suffix="+" />          {/* Years */}
```

